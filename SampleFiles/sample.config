<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Datenbankverbindungsstring -->
    <add key="DatabaseHost" value="localhost" />
    <!-- Datenbank-Port -->
    <add key="DatabasePort" value="1433" />
    <!-- Name der Datenbank -->
    <add key="DatabaseName" value="ProductionDB" />
    <!-- API-Schlüssel für externen Dienst -->
    <add key="ApiKey" value="abc123xyz" />
    <!-- Timeout in Millisekunden -->
    <add key="RequestTimeout" value="30000" />
    <!-- Debug-Modus aktiv -->
    <add key="DebugMode" value="false" />
    <!-- Maximale Wiederholungsversuche -->
    <add key="MaxRetries" value="3" />
    <!-- Anwendungsumgebung -->
    <add key="Environment" value="Production" />
    <!-- Feature-Flag: Neue Benutzeroberfläche -->
    <add key="FeatureNewUI" value="false" />
    <!-- Maximale Dateigröße für Uploads (Bytes) -->
    <add key="MaxUploadSize" value="10485760" />
  </appSettings>
</configuration>
